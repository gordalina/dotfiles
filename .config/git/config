[user]
    name = Samuel Gordalina
    email = samuel.gordalina@gmail.com
    signingKey = ~/.ssh/id_secretive.pub

[commit]
    gpgSign = true

[tag]
    gpgSign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.ssh/id_secretive.pub
    program = ~/.ssh/git-signing-wrapper.sh

[alias]
    unstash = "stash pop"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true